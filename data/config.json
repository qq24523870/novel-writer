{
    "app": {
        "name": "AI小说创作助手",
        "version": "1.0.0",
        "window_width": 1400,
        "window_height": 900,
        "min_width": 1000,
        "min_height": 700,
        "first_run": false
    },
    "editor": {
        "font_family": "Microsoft YaHei",
        "font_size": 19,
        "line_spacing": 1.5,
        "auto_save_interval": 30,
        "tab_width": 4,
        "auto_indent": true,
        "show_line_numbers": true,
        "wrap_mode": true,
        "max_undo_levels": 1000
    },
    "ai": {
        "default_model": "siliconflow",
        "temperature": 0.8,
        "max_tokens": 2048,
        "top_p": 0.9,
        "frequency_penalty": 0.3,
        "presence_penalty": 0.3,
        "local_model": {
            "enabled": false,
            "model_path": "",
            "n_ctx": 4096,
            "n_gpu_layers": 0,
            "n_threads": 4,
            "verbose": false
        },
        "cloud_models": {
            "openai": {
                "enabled": false,
                "api_key": "",
                "api_base": "https://api.openai.com/v1",
                "model": "gpt-3.5-turbo"
            },
            "wenxin": {
                "enabled": false,
                "api_key": "",
                "secret_key": "",
                "model": "ernie-3.5-8k"
            },
            "tongyi": {
                "enabled": false,
                "api_key": "",
                "model": "qwen-turbo"
            },
            "doubao": {
                "enabled": false,
                "api_key": "",
                "model": "doubao-pro-32k"
            },
            "custom": {
                "enabled": false,
                "api_key": "",
                "api_base": "",
                "model": ""
            },
            "siliconflow": {
                "enabled": true,
                "api_key": "sk-gmnmddblgmffkrbqpoekdnhpfouydnkdgwbqatpwkimisujw",
                "model": "deepseek-ai/DeepSeek-V3.2",
                "api_base": "https://api.siliconflow.cn/v1"
            },
            "deepseek": {
                "enabled": false,
                "api_key": "",
                "model": "deepseek-reasoner"
            }
        }
    },
    "writing": {
        "daily_word_goal": 3000,
        "typing_sound": true,
        "typing_sound_volume": 50,
        "typing_sound_theme": "mechanical",
        "lock_mode": false,
        "lock_duration": 0,
        "auto_backup": true,
        "backup_interval": 300,
        "backup_dir": "",
        "continue_word_count": 1000,
        "generate_chapter_count": 5,
        "generate_word_per_chapter": 2000
    },
    "theme": {
        "current": "light",
