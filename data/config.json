    "shortcuts": {
        "new_chapter": "Ctrl+N",
        "save": "Ctrl+S",
        "save_all": "Ctrl+Shift+S",
        "bold": "Ctrl+B",
        "italic": "Ctrl+I",
        "underline": "Ctrl+U",
        "find": "Ctrl+F",
        "replace": "Ctrl+H",
        "ai_continue": "Ctrl+E",
        "ai_polish": "Ctrl+R",
        "ai_expand": "Ctrl+Shift+E",
        "ai_summarize": "Ctrl+Shift+R",
        "fullscreen": "F11",
        "focus_mode": "Ctrl+Shift+F",
        "toggle_sidebar": "Ctrl+\\",
        "toggle_ai_panel": "Ctrl+Shift+A",
        "undo": "Ctrl+Z",
        "redo": "Ctrl+Y",
        "word_count": "Ctrl+Shift+C"
    }
